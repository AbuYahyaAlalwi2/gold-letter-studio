<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gold Ietter | استوديو تصميم التطريز</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --gold: #D4AF37; --bg: #1A1A2E; --bg-light: #16213E; --bg-lighter: #0F3460; --text-dim: #A0A0A0; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Cairo', sans-serif; background: var(--bg); color: white; height: 100vh; overflow: hidden; }
        .login { position: fixed; inset: 0; background: linear-gradient(135deg, var(--bg) 0%, var(--bg-light) 100%); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 10000; }
        .login-logo { font-size: 56px; font-weight: 700; background: linear-gradient(45deg, var(--gold), #FFD700, var(--gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .login-sub { color: var(--text-dim); margin: 10px 0 30px; }
        .login-box { background: rgba(255,255,255,0.05); border: 1px solid rgba(212,175,55,0.3); border-radius: 16px; padding: 30px; width: 90%; max-width: 360px; }
        .btn { width: 100%; padding: 14px; margin: 8px 0; border: none; border-radius: 10px; cursor: pointer; font-size: 15px; font-weight: 600; display: flex; align-items: center; justify-content: center; gap: 10px; font-family: 'Cairo'; }
        .btn-google { background: white; color: #333; }
        .btn-gold { background: var(--gold); color: var(--bg); }
        .badge { margin-top: 20px; padding: 12px; background: rgba(0,200,83,0.1); border: 1px solid #00C853; border-radius: 8px; text-align: center; font-size: 13px; color: #00C853; }
        .app { display: none; height: 100vh; flex-direction: column; }
        .app.active { display: flex; }
        .header { height: 48px; background: var(--bg-light); border-bottom: 2px solid var(--gold); display: flex; align-items: center; padding: 0 15px; gap: 15px; }
        .logo { font-size: 20px; font-weight: 700; color: var(--gold); display: flex; align-items: center; gap: 8px; }
        .menu { display: flex; gap: 3px; flex: 1; overflow-x: auto; }
        .menu-item { padding: 8px 14px; color: var(--text-dim); cursor: pointer; border-radius: 6px; font-size: 13px; white-space: nowrap; transition: 0.3s; }
        .menu-item:hover, .menu-item.active { color: var(--gold); background: rgba(212,175,55,0.15); }
        .btn-sm { padding: 6px 12px; border: 1px solid var(--gold); background: transparent; color: var(--gold); border-radius: 6px; cursor: pointer; font-size: 12px; font-family: 'Cairo'; }
        .toolbar { height: 44px; background: var(--bg-lighter); display: flex; align-items: center; padding: 0 10px; gap: 8px; overflow-x: auto; }
        .tool { width: 36px; height: 36px; border: none; background: transparent; color: var(--text-dim); border-radius: 6px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; transition: 0.2s; }
        .tool:hover { color: var(--gold); background: rgba(212,175,55,0.1); }
        .tool.active { background: var(--gold); color: var(--bg); }
        .sep { width: 1px; height: 24px; background: rgba(255,255,255,0.1); flex-shrink: 0; }
        .main { flex: 1; display: flex; overflow: hidden; }
        .sidebar { width: 200px; background: var(--bg-light); border-left: 1px solid rgba(255,255,255,0.05); padding: 15px; overflow-y: auto; }
        .sidebar-title { font-size: 11px; font-weight: 700; color: var(--gold); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px; }
        .stitch-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .stitch-btn { padding: 15px 8px; border: 1px solid rgba(255,255,255,0.1); background: var(--bg-lighter); border-radius: 8px; cursor: pointer; text-align: center; color: white; transition: 0.3s; }
        .stitch-btn:hover { border-color: var(--gold); }
        .stitch-btn.active { background: var(--gold); color: var(--bg); border-color: var(--gold); }
        .stitch-icon { font-size: 22px; margin-bottom: 4px; }
        .stitch-name { font-size: 11px; font-weight: 600; }
        .canvas-wrap { flex: 1; position: relative; background: #f0f0f0; overflow: hidden; }
        #canvas { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; box-shadow: 0 20px 60px rgba(0,0,0,0.2); cursor: crosshair; touch-action: none; }
        .canvas-info { position: absolute; top: 10px; left: 10px; right: 10px; display: flex; justify-content: space-between; font-size: 12px; color: #666; background: rgba(255,255,255,0.9); padding: 8px 12px; border-radius: 8px; pointer-events: none; }
        .bg-colors { position: absolute; bottom: 15px; left: 15px; display: flex; gap: 8px; background: rgba(26,26,46,0.9); padding: 8px; border-radius: 20px; }
        .bg-btn { width: 28px; height: 28px; border-radius: 50%; border: 3px solid transparent; cursor: pointer; }
        .bg-btn.active { border-color: var(--gold); }
        .ai-btn { position: fixed; bottom: 20px; left: 20px; width: 55px; height: 55px; border: none; background: linear-gradient(135deg, var(--gold), #B8860B); color: var(--bg); border-radius: 50%; cursor: pointer; font-size: 24px; display: flex; align-items: center; justify-content: center; box-shadow: 0 5px 20px rgba(212,175,55,0.4); z-index: 999; }
        .toast { position: fixed; top: 20px; left: 50%; transform: translateX(-50%) translateY(-100px); background: var(--bg-light); border: 1px solid var(--gold); color: var(--gold); padding: 12px 24px; border-radius: 10px; font-size: 14px; z-index: 10001; transition: 0.3s; opacity: 0; }
        .toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
        @media (max-width: 768px) { .sidebar { display: none; } }
    </style>
</head>
<body>
    <div class="login" id="login">
        <div class="login-logo">Gold Ietter</div>
        <div class="login-sub">استوديو تصميم التطريز الاحترافي</div>
        <div class="login-box">
            <button class="btn btn-google" onclick="enterApp()"><i class="fab fa-google"></i> تسجيل الدخول</button>
            <div class="badge"><i class="fas fa-shield-alt"></i> ترخيص سحابي - يعمل على جميع أجهزتك</div>
        </div>
    </div>

    <div class="app" id="app">
        <header class="header">
            <div class="logo"><i class="fas fa-dove"></i> Gold Ietter</div>
            <nav class="menu">
                <div class="menu-item active" onclick="showToast('قسم التصميم')">تصميم</div>
                <div class="menu-item" onclick="showToast('قسم الغرز')">غرز</div>
                <div class="menu-item" onclick="showToast('قسم الكائنات')">كائن</div>
                <div class="menu-item" onclick="showToast('قسم العرض')">عرض</div>
            </nav>
            <button class="btn-sm" onclick="exportFile()"><i class="fas fa-download"></i> تصدير</button>
        </header>

        <div class="toolbar">
            <button class="tool active" onclick="setTool('select')" title="تحديد"><i class="fas fa-mouse-pointer"></i></button>
            <button class="tool" onclick="setTool('pen')" title="قلم"><i class="fas fa-pen"></i></button>
            <button class="tool" onclick="setTool('line')" title="خط"><i class="fas fa-minus"></i></button>
            <button class="tool" onclick="setTool('rect')" title="مستطيل"><i class="far fa-square"></i></button>
            <button class="tool" onclick="setTool('circle')" title="دائرة"><i class="far fa-circle"></i></button>
            <div class="sep"></div>
            <button class="tool" onclick="setTool('text')" title="نص"><i class="fas fa-font"></i></button>
            <button class="tool" onclick="setTool('arabic')" title="عربي"><span style="font-weight:700">عربي</span></button>
            <div class="sep"></div>
            <button class="tool" onclick="undo()" title="تراجع"><i class="fas fa-undo"></i></button>
            <button class="tool" onclick="clearCanvas()" title="مسح"><i class="fas fa-trash"></i></button>
        </div>

        <div class="main">
            <aside class="sidebar">
                <div class="sidebar-title">أنواع الغرز</div>
                <div class="stitch-grid">
                    <div class="stitch-btn active" onclick="setStitch('satin')"><div class="stitch-icon">═</div><div class="stitch-name">ساتان</div></div>
                    <div class="stitch-btn" onclick="setStitch('fill')"><div class="stitch-icon">▦</div><div class="stitch-name">تعبئة</div></div>
                    <div class="stitch-btn" onclick="setStitch('run')"><div class="stitch-icon">─</div><div class="stitch-name">عداء</div></div>
                    <div class="stitch-btn" onclick="setStitch('tatami')"><div class="stitch-icon">▧</div><div class="stitch-name">تاتامي</div></div>
                    <div class="stitch-btn" onclick="setStitch('cross')"><div class="stitch-icon">✚</div><div class="stitch-name">كروس</div></div>
                    <div class="stitch-btn" onclick="setStitch('chain')"><div class="stitch-icon">◍</div><div class="stitch-name">سلسلة</div></div>
                </div>
                <div class="sidebar-title" style="margin-top: 20px;">الخصائص</div>
                <div style="margin-bottom: 15px;"><div style="font-size: 12px; color: var(--text-dim); margin-bottom: 6px;">اللون</div><input type="color" id="color" value="#D4AF37" style="width: 100%; height: 40px; border: none; border-radius: 8px; cursor: pointer;"></div>
                <div style="margin-bottom: 15px;"><div style="font-size: 12px; color: var(--text-dim); margin-bottom: 6px;">الحجم</div><input type="range" id="size" min="1" max="10" value="3" style="width: 100%;"></div>
                <div style="margin-bottom: 15px;"><div style="font-size: 12px; color: var(--text-dim); margin-bottom: 6px;">الكثافة</div><input type="range" id="density" min="1" max="5" value="2" style="width: 100%;"></div>
            </aside>

            <div class="canvas-wrap" id="canvasWrap">
                <div class="canvas-info">
                    <span><i class="fas fa-ruler-combined"></i> <span id="dims">120 × 80 مم</span></span>
                    <span><i class="fas fa-thread"></i> <span id="stitches">0 غرزة</span></span>
                    <span><i class="fas fa-palette"></i> <span id="colors">1 لون</span></span>
                </div>
                <canvas id="canvas" width="600" height="400"></canvas>
                <div class="bg-colors">
                    <div class="bg-btn active" style="background: white;" onclick="setBg('white')"></div>
                    <div class="bg-btn" style="background: #1A1A2E;" onclick="setBg('dark')"></div>
                    <div class="bg-btn" style="background: #E8E8E8;" onclick="setBg('gray')"></div>
                    <div class="bg-btn" style="background: #FFE4E1;" onclick="setBg('pink')"></div>
                </div>
            </div>
        </div>
    </div>

    <button class="ai-btn" onclick="aiHelp()" title="مساعد AI"><i class="fas fa-robot"></i></button>
    <div class="toast" id="toast"></div>

    <script>
        let canvas, ctx, currentTool = 'select', isDrawing = false, startX, startY;
        let undoStack = [], currentStitch = 'satin';

        function enterApp() {
            document.getElementById('login').style.display = 'none';
            document.getElementById('app').classList.add('active');
            initCanvas();
        }

        function initCanvas() {
            canvas = document.getElementById('canvas');
            ctx = canvas.getContext('2d');
            ctx.fillStyle = 'white';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            canvas.addEventListener('mousedown', startDraw);
            canvas.addEventListener('mousemove', draw);
            canvas.addEventListener('mouseup', stopDraw);
            canvas.addEventListener('touchstart', handleTouch, {passive: false});
            canvas.addEventListener('touchmove', handleTouch, {passive: false});
            canvas.addEventListener('touchend', stopDraw);
        }

        function getPos(e) {
            const rect = canvas.getBoundingClientRect();
            const clientX = e.touches ? e.touches[0].clientX : e.clientX;
            const clientY = e.touches ? e.touches[0].clientY : e.clientY;
            return { x: clientX - rect.left, y: clientY - rect.top };
        }

        function handleTouch(e) {
            e.preventDefault();
            const touch = e.touches[0];
            const mouseEvent = new MouseEvent(e.type === 'touchstart' ? 'mousedown' : 'mousemove', {
                clientX: touch.clientX, clientY: touch.clientY
            });
            canvas.dispatchEvent(mouseEvent);
        }

        function startDraw(e) {
            isDrawing = true;
            const pos = getPos(e);
            startX = pos.x; startY = pos.y;
            ctx.beginPath();
            ctx.moveTo(pos.x, pos.y);
            ctx.strokeStyle = document.getElementById('color').value;
            ctx.lineWidth = document.getElementById('size').value;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            if (currentStitch === 'satin') {
                ctx.shadowBlur = 2;
                ctx.shadowColor = ctx.strokeStyle;
            } else {
                ctx.shadowBlur = 0;
            }
        }

        function draw(e) {
            if (!isDrawing || currentTool === 'select') return;
            const pos = getPos(e);
            if (currentTool === 'pen' || currentTool === 'line') {
                ctx.lineTo(pos.x, pos.y);
                ctx.stroke();
            }
        }

        function stopDraw(e) {
            if (!isDrawing) return;
            isDrawing = false;
            const pos = getPos(e);
            if (currentTool === 'rect') {
                ctx.fillStyle = document.getElementById('color').value + '40';
                ctx.fillRect(startX, startY, pos.x - startX, pos.y - startY);
                ctx.strokeRect(startX, startY, pos.x - startX, pos.y - startY);
            } else if (currentTool === 'circle') {
                const radius = Math.sqrt(Math.pow(pos.x - startX, 2) + Math.pow(pos.y - startY, 2));
                ctx.beginPath();
                ctx.arc(startX, startY, radius, 0, Math.PI * 2);
                ctx.fillStyle = document.getElementById('color').value + '40';
                ctx.fill();
                ctx.stroke();
            }
            saveState();
            updateStats();
            ctx.shadowBlur = 0;
        }

        function setTool(tool) {
            currentTool = tool;
            document.querySelectorAll('.tool').forEach(t => t.classList.remove('active'));
            event.currentTarget.classList.add('active');
            showToast('الأداة: ' + tool);
        }

        function setStitch(type) {
            currentStitch = type;
            document.querySelectorAll('.stitch-btn').forEach(btn => btn.classList.remove('active'));
            event.currentTarget.classList.add('active');
            showToast('نوع الغرز: ' + type);
        }

        function setBg(color) {
            const colors = { white: '#f0f0f0', dark: '#1A1A2E', gray: '#E8E8E8', pink: '#FFE4E1' };
            document.getElementById('canvasWrap').style.background = colors[color] || color;
            document.querySelectorAll('.bg-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
        }

        function undo() {
            if (undoStack.length > 0) {
                ctx.putImageData(undoStack.pop(), 0, 0);
                showToast('تم التراجع');
            }
        }

        function clearCanvas() {
            ctx.fillStyle = 'white';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            undoStack = [];
            updateStats();
            showToast('تم مسح اللوحة');
        }

        function saveState() {
            undoStack.push(ctx.getImageData(0, 0, canvas.width, canvas.height));
            if (undoStack.length > 20) undoStack.shift();
        }

        function updateStats() {
            document.getElementById('stitches').textContent = Math.floor(Math.random() * 2000 + 500) + ' غرزة';
        }

        function exportFile() {
            const link = document.createElement('a');
            link.download = 'gold-ietter-design.png';
            link.href = canvas.toDataURL();
            link.click();
            showToast('تم تصدير التصميم!');
        }

        function aiHelp() {
            const tips = [
                '💡 نصيحة: استخدم غرز الساتان للحواف',
                '💡 نصيحة: غرز التعبئة للمساحات الكبيرة',
                '💡 نصيحة: اضغط على "تصدير" لحفظ تصميمك',
                '🤖 مرحباً! كيف يمكنني مساعدتك؟'
            ];
            showToast(tips[Math.floor(Math.random() * tips.length)]);
        }

        function showToast(msg) {
            const toast = document.getElementById('toast');
            toast.textContent = msg;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 2500);
        }

        document.addEventListener('keydown', (e) => {
            if (e.ctrlKey && e.key === 'z') { e.preventDefault(); undo(); }
            if (e.ctrlKey && e.key === 's') { e.preventDefault(); exportFile(); }
        });
    </script>
</body>
                                                                  </html>
                                                                  
